#!/bin/sh
# RustOS userspace PID 1: boot into installed system, installer, live session, or desktop.
# chmod +x userspace/rootfs/init

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PATH

INSTALLED_MARKER=/etc/rustos-installed
LIVE_SQUASH=/live/filesystem.squashfs
OVERLAY_ROOT=/run/overlay/root
OVERLAY_UPPER=/run/overlay/upper
OVERLAY_WORK=/run/overlay/work
INSTALLED_MOUNT=/mnt/installed-root

mount_if_needed() {
    target=$1
    type=$2
    source=$3

    mkdir -p "$target" 2>/dev/null || true
    if ! grep -q " $target " /proc/mounts 2>/dev/null; then
        mount -t "$type" "$source" "$target" 2>/dev/null || true
    fi
}

make_node() {
    path=$1
    type=$2
    major=$3
    minor=$4

    if [ ! -e "$path" ]; then
        mknod "$path" "$type" "$major" "$minor" 2>/dev/null || true
    fi
}

read_installed_value() {
    key=$1
    default=${2:-}
    if [ ! -f "$INSTALLED_MARKER" ]; then
        printf '%s' "$default"
        return 0
    fi
    value=$(grep -E "^${key}=" "$INSTALLED_MARKER" 2>/dev/null | head -n1 | cut -d= -f2-)
    if [ -n "$value" ]; then
        printf '%s' "$value"
    else
        printf '%s' "$default"
    fi
}

mount_partition() {
    dev=$1
    mountpoint=$2
    fstype=${3:-}
    mkdir -p "$mountpoint" 2>/dev/null || true
    if [ -n "$fstype" ]; then
        mount -t "$fstype" "$dev" "$mountpoint" 2>/dev/null && return 0
    fi
    mount "$dev" "$mountpoint" 2>/dev/null
}

mount_installed_root() {
    if [ ! -f "$INSTALLED_MARKER" ]; then
        return 1
    fi

    root_part=$(read_installed_value root_part "")
    root_fs=$(read_installed_value root_fs ext4)
    efi_part=$(read_installed_value efi_part "")
    efi_fs=$(read_installed_value efi_fs vfat)

    if [ -z "$root_part" ]; then
        echo "RustOS: installed marker present but root_part missing"
        return 1
    fi

    if [ ! -b "$root_part" ]; then
        echo "RustOS: installed root $root_part not available"
        return 1
    fi

    mkdir -p "$INSTALLED_MOUNT" 2>/dev/null || true
    if ! mount_partition "$root_part" "$INSTALLED_MOUNT" "$root_fs"; then
        echo "RustOS: failed to mount installed root $root_part"
        return 1
    fi

    if [ -n "$efi_part" ] && [ -b "$efi_part" ]; then
        mkdir -p "$INSTALLED_MOUNT/boot/efi" 2>/dev/null || true
        mount_partition "$efi_part" "$INSTALLED_MOUNT/boot/efi" "$efi_fs" || true
    fi

    if [ -f "$INSTALLED_MOUNT/etc/rustos/first-boot" ] && grep -q pending "$INSTALLED_MOUNT/etc/rustos/first-boot" 2>/dev/null; then
        if [ -x "$INSTALLED_MOUNT/usr/bin/rustos-installer-postinstall" ]; then
            echo "RustOS: running first-boot postinstall in installed root"
            if command -v chroot >/dev/null 2>&1; then
                mkdir -p "$INSTALLED_MOUNT/proc" "$INSTALLED_MOUNT/sys" "$INSTALLED_MOUNT/dev" 2>/dev/null || true
                mount -t proc proc "$INSTALLED_MOUNT/proc" 2>/dev/null || true
                mount -t sysfs sysfs "$INSTALLED_MOUNT/sys" 2>/dev/null || true
                mount --bind /dev "$INSTALLED_MOUNT/dev" 2>/dev/null || true
                chroot "$INSTALLED_MOUNT" /usr/bin/rustos-installer-postinstall --chroot
                umount "$INSTALLED_MOUNT/dev" 2>/dev/null || true
                umount "$INSTALLED_MOUNT/sys" 2>/dev/null || true
                umount "$INSTALLED_MOUNT/proc" 2>/dev/null || true
            fi
        fi
    fi

    if command -v switch_root >/dev/null 2>&1; then
        echo "RustOS: switching root to installed system at $INSTALLED_MOUNT"
        for dir in dev proc sys run tmp; do
            mount --bind "/$dir" "$INSTALLED_MOUNT/$dir" 2>/dev/null || true
        done
        exec switch_root "$INSTALLED_MOUNT" /init
    fi

    if command -v pivot_root >/dev/null 2>&1; then
        echo "RustOS: pivoting to installed root at $INSTALLED_MOUNT"
        mkdir -p "$INSTALLED_MOUNT/old" 2>/dev/null || true
        pivot_root "$INSTALLED_MOUNT" "$INSTALLED_MOUNT/old" 2>/dev/null || return 1
        for dir in dev proc sys run; do
            mount --bind "/$dir" "/$dir" 2>/dev/null || true
        done
        umount -l /old 2>/dev/null || true
        exec /init
    fi

    echo "RustOS: switch_root/pivot_root unavailable — continuing from mounted installed root"
    return 0
}

mount_squashfs_overlay() {
    squash=$1
    if [ ! -f "$squash" ]; then
        return 1
    fi

    mkdir -p "$OVERLAY_ROOT" "$OVERLAY_UPPER" "$OVERLAY_WORK" /run/live/rootfs 2>/dev/null || true

    if command -v losetup >/dev/null 2>&1; then
        loop=$(losetup -f 2>/dev/null) || loop=/dev/loop0
        losetup "$loop" "$squash" 2>/dev/null || true
        if mount -t squashfs "$loop" /run/live/rootfs 2>/dev/null; then
            echo "RustOS: mounted squashfs via $loop"
        else
            losetup -d "$loop" 2>/dev/null || true
        fi
    fi

    if ! grep -q " /run/live/rootfs " /proc/mounts 2>/dev/null; then
        if ! mount -t squashfs "$squash" /run/live/rootfs 2>/dev/null; then
            echo "RustOS: squashfs mount failed — using directory overlay stub for QEMU"
            mkdir -p /run/live/rootfs
            if [ -d /ro ]; then
                cp -a /ro/. /run/live/rootfs/ 2>/dev/null || true
            fi
        fi
    fi

    if mount -t overlay overlay -o lowerdir=/run/live/rootfs,upperdir=$OVERLAY_UPPER,workdir=$OVERLAY_WORK "$OVERLAY_ROOT" 2>/dev/null; then
        echo "RustOS: overlay mounted at $OVERLAY_ROOT"
    else
        echo "RustOS: overlay mount unavailable — binding squashfs root"
        mkdir -p "$OVERLAY_ROOT"
        mount --bind /run/live/rootfs "$OVERLAY_ROOT" 2>/dev/null || {
            cp -a /run/live/rootfs/. "$OVERLAY_ROOT/" 2>/dev/null || true
        }
    fi

    for dir in proc sys dev run tmp; do
        mkdir -p "$OVERLAY_ROOT/$dir" 2>/dev/null || true
        mount --bind "/$dir" "$OVERLAY_ROOT/$dir" 2>/dev/null ||         mount -t tmpfs tmpfs "$OVERLAY_ROOT/$dir" 2>/dev/null || true
    done

    if command -v switch_root >/dev/null 2>&1 && [ -x "$OVERLAY_ROOT/usr/bin/rustos-live-session" ]; then
        exec switch_root "$OVERLAY_ROOT" /usr/bin/rustos-live-session
    fi

    if command -v chroot >/dev/null 2>&1 && [ -x "$OVERLAY_ROOT/usr/bin/rustos-live-session" ]; then
        export RUSTOS_LIVE=1
        exec chroot "$OVERLAY_ROOT" /usr/bin/rustos-live-session
    fi

    export RUSTOS_LIVE=1
    if [ -x /usr/bin/rustos-live-session ]; then
        exec /usr/bin/rustos-live-session
    fi
    return 0
}

# --- early bring-up ---
mount_if_needed /proc proc proc
mount_if_needed /sys sysfs sysfs
mount_if_needed /dev devtmpfs devtmpfs
mount_if_needed /run tmpfs tmpfs
mount_if_needed /tmp tmpfs tmpfs

mkdir -p /run/user/0 /dev/input /dev/dri /run/installer /live 2>/dev/null || true
chmod 700 /run/user/0 2>/dev/null || true
chmod 1777 /tmp 2>/dev/null || true

make_node /dev/console c 5 1
make_node /dev/null c 1 3
make_node /dev/zero c 1 5
make_node /dev/tty c 5 0

export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/0}
export XDG_CURRENT_DESKTOP=${XDG_CURRENT_DESKTOP:-ubuntu:GNOME}
export XDG_SESSION_DESKTOP=${XDG_SESSION_DESKTOP:-ubuntu}
export XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-wayland}
export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
export DBUS_SESSION_BUS_ADDRESS=${DBUS_SESSION_BUS_ADDRESS:-unix:path=$XDG_RUNTIME_DIR/bus}
export GDK_BACKEND=${GDK_BACKEND:-wayland}
export CLUTTER_BACKEND=${CLUTTER_BACKEND:-wayland}
export NO_AT_BRIDGE=${NO_AT_BRIDGE:-1}

# Live session marker from kernel spawn or ISO
if [ -f /run/rustos/live ]; then
    export RUSTOS_LIVE=1
    export RUSTOS_BOOT=${RUSTOS_BOOT:-live}
fi

# --- boot decision tree ---
if [ -f "$INSTALLED_MARKER" ] && mount_installed_root; then
    echo "RustOS: booted installed system"
    if [ -x /usr/bin/rustos-gnome-session ]; then
        exec /usr/bin/rustos-gnome-session
    fi
elif [ -f /run/installer/active ] || [ "${RUSTOS_BOOT:-}" = install ]; then
    echo "RustOS: starting GTK installer"
    if [ -x /usr/bin/rustos-installer-gtk-session ]; then
        exec /usr/bin/rustos-installer-gtk-session
    elif [ -x /usr/bin/rustos-installer-ui ]; then
        exec /usr/bin/rustos-installer-ui
    elif [ -x /usr/bin/rustos-installer ]; then
        exec /usr/bin/rustos-installer
    fi
elif [ -f "$LIVE_SQUASH" ]; then
    echo "RustOS: starting live session (squashfs)"
    mount_squashfs_overlay "$LIVE_SQUASH"
else
    echo "RustOS: starting Ubuntu desktop session"
    if [ -x /usr/bin/rustos-gnome-session ]; then
        exec /usr/bin/rustos-gnome-session
    fi
fi

echo "RustOS: no session launcher available; entering emergency shell"
exec /bin/sh
