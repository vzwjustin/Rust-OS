#!/bin/sh
# RustOS GNOME session bootstrap.
#
# This launcher is intentionally diagnostic-first. It prepares the runtime
# directories GNOME expects, probes the OS facilities that must exist before
# gnome-shell can run, and reports the first blockers instead of looping on a
# doomed shell launch.

set -u

STATUS_FILE=${RUSTOS_GNOME_STATUS_FILE:-/run/rustos-gnome-session.status}
RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/0}
SESSION_BUS=${DBUS_SESSION_BUS_ADDRESS:-unix:path=$RUNTIME_DIR/bus}

export XDG_RUNTIME_DIR=$RUNTIME_DIR
export DBUS_SESSION_BUS_ADDRESS=$SESSION_BUS
export XDG_CURRENT_DESKTOP=${XDG_CURRENT_DESKTOP:-GNOME}
export XDG_SESSION_DESKTOP=${XDG_SESSION_DESKTOP:-gnome}
export XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-wayland}
export GDK_BACKEND=${GDK_BACKEND:-wayland,x11}
export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
export CLUTTER_BACKEND=${CLUTTER_BACKEND:-wayland}
export NO_AT_BRIDGE=${NO_AT_BRIDGE:-1}

log() {
    echo "rustos-gnome-session: $*"
}

status() {
    log "$*"
    printf '%s\n' "$*" >> "$STATUS_FILE"
}

reset_status() {
    mkdir -p "$(dirname "$STATUS_FILE")" 2>/dev/null || true
    : > "$STATUS_FILE" 2>/dev/null || true
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

require_path() {
    if [ -e "$1" ]; then
        status "ready: $2 ($1)"
        return 0
    fi

    status "blocked: $2 missing ($1)"
    return 1
}


start_wayland_compositor() {
    wayland_socket="$RUNTIME_DIR/$WAYLAND_DISPLAY"

    if [ -S "$wayland_socket" ] || [ -e "$wayland_socket" ]; then
        status "ready: Wayland display socket ($wayland_socket)"
        return 0
    fi

    if have_command rustos-mutter; then
        rustos-mutter --probe >/dev/null 2>&1 && {
            status "ready: kernel Wayland compositor ($wayland_socket)"
            return 0
        }
    fi

    if have_command mutter; then
        mutter --wayland --wayland-display="$WAYLAND_DISPLAY" >/dev/null 2>&1 &
        sleep 1
        if [ -S "$wayland_socket" ] || [ -e "$wayland_socket" ]; then
            status "ready: Mutter started ($wayland_socket)"
            return 0
        fi
        status "blocked: mutter failed to create $wayland_socket"
        return 1
    fi

    status "blocked: Wayland compositor missing (mutter or rustos-mutter)"
    return 1
}

start_session_bus() {
    mkdir -p "$RUNTIME_DIR" 2>/dev/null || true
    chmod 700 "$RUNTIME_DIR" 2>/dev/null || true

    case "$DBUS_SESSION_BUS_ADDRESS" in
        unix:path=*)
            bus_path=${DBUS_SESSION_BUS_ADDRESS#unix:path=}
            ;;
        *)
            bus_path=$RUNTIME_DIR/bus
            ;;
    esac

    if [ -S "$bus_path" ]; then
        status "ready: D-Bus session bus ($bus_path)"
        return 0
    fi

    if [ -e "$bus_path" ]; then
        status "ready: D-Bus session bus path present ($bus_path)"
        return 0
    fi

    if have_command dbus-daemon; then
        dbus-daemon --session --fork --address="$DBUS_SESSION_BUS_ADDRESS" >/dev/null 2>&1 || true
        if [ -S "$bus_path" ]; then
            status "ready: D-Bus session bus started ($bus_path)"
            return 0
        fi
        status "blocked: dbus-daemon exists but did not create $bus_path"
        return 1
    fi

    status "blocked: dbus-daemon missing"
    return 1
}

probe_foundation() {
    ok=0

    reset_status
    status "probe: RustOS GNOME userspace overlay"

    if [ -d "$RUNTIME_DIR" ] || mkdir -p "$RUNTIME_DIR" 2>/dev/null; then
        chmod 700 "$RUNTIME_DIR" 2>/dev/null || true
        status "ready: XDG_RUNTIME_DIR ($RUNTIME_DIR)"
    else
        status "blocked: cannot create XDG_RUNTIME_DIR ($RUNTIME_DIR)"
        ok=1
    fi

    start_session_bus || ok=1

    start_wayland_compositor || ok=1

    if [ -e /dev/dri/card0 ] || [ -e /dev/dri/renderD128 ]; then
        status "ready: DRM device node"
    else
        status "blocked: DRM device node missing (/dev/dri/card0 or renderD128)"
        ok=1
    fi

    if [ -d /dev/input ]; then
        status "ready: input device directory (/dev/input)"
    else
        status "blocked: input device directory missing (/dev/input)"
        ok=1
    fi

    require_path /proc "procfs" || ok=1
    require_path /sys "sysfs" || ok=1
    require_path /tmp "tmpfs/work directory" || ok=1

    if have_command gnome-shell; then
        status "ready: gnome-shell binary"
    else
        status "blocked: gnome-shell binary missing"
        ok=1
    fi

    if have_command mutter || have_command rustos-mutter; then
        status "ready: mutter compositor launcher"
    else
        status "blocked: mutter compositor launcher missing"
        ok=1
    fi

    return "$ok"
}

case "${1:-}" in
    --probe|--status)
        probe_foundation
        exit $?
        ;;
    --print-env)
        printf 'XDG_RUNTIME_DIR=%s\n' "$XDG_RUNTIME_DIR"
        printf 'DBUS_SESSION_BUS_ADDRESS=%s\n' "$DBUS_SESSION_BUS_ADDRESS"
        printf 'XDG_CURRENT_DESKTOP=%s\n' "$XDG_CURRENT_DESKTOP"
        printf 'XDG_SESSION_TYPE=%s\n' "$XDG_SESSION_TYPE"
        printf 'WAYLAND_DISPLAY=%s\n' "$WAYLAND_DISPLAY"
        exit 0
        ;;
esac

if ! probe_foundation; then
    status "result: GNOME launch blocked; see $STATUS_FILE"
    exit 1
fi

start_wayland_compositor || {
    status "result: GNOME launch blocked; Wayland compositor unavailable"
    exit 1
}

status "result: launching gnome-shell"
exec gnome-shell --wayland
