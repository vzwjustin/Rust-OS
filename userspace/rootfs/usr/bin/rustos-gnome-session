#!/bin/sh
# RustOS GNOME Wayland session bootstrap.

set -u

STATUS_FILE=${RUSTOS_GNOME_STATUS_FILE:-/run/rustos-gnome-session.status}
RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/0}
SESSION_BUS=${DBUS_SESSION_BUS_ADDRESS:-unix:path=$RUNTIME_DIR/bus}
GNOME_PROC=${RUSTOS_GNOME_PROC:-/proc/rustos/gnome}

export XDG_RUNTIME_DIR=$RUNTIME_DIR
export DBUS_SESSION_BUS_ADDRESS=$SESSION_BUS
export XDG_CURRENT_DESKTOP=${XDG_CURRENT_DESKTOP:-ubuntu:GNOME}
export XDG_SESSION_DESKTOP=${XDG_SESSION_DESKTOP:-ubuntu}
export XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-wayland}
export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
export GDK_BACKEND=${GDK_BACKEND:-wayland}
export CLUTTER_BACKEND=${CLUTTER_BACKEND:-wayland}
export NO_AT_BRIDGE=${NO_AT_BRIDGE:-1}

log() {
    echo "rustos-gnome-session: $*"
}

status() {
    mkdir -p "$(dirname "$STATUS_FILE")" 2>/dev/null || true
    printf '%s\n' "$*" >> "$STATUS_FILE" 2>/dev/null || true
    log "$*"
}


apply_ubuntu_theme() {
    if have_command rustos-ubuntu-theme; then
        rustos-ubuntu-theme apply && status "ready: Ubuntu theme defaults" ||             status "info: Ubuntu theme defaults skipped"
    fi
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

read_proc_key() {
    if [ ! -r "$GNOME_PROC" ]; then
        echo unknown
        return 0
    fi

    grep -E "^$1=" "$GNOME_PROC" 2>/dev/null | head -n1 | cut -d= -f2-
}

prepare_runtime() {
    mkdir -p "$RUNTIME_DIR" /tmp 2>/dev/null || true
    chmod 700 "$RUNTIME_DIR" 2>/dev/null || true
    chmod 1777 /tmp 2>/dev/null || true
    : > "$STATUS_FILE" 2>/dev/null || true
}

probe_foundation() {
    ok=0

    prepare_runtime
    status "boot: Ubuntu desktop session"

    if [ -r "$GNOME_PROC" ]; then
        status "ready: kernel GNOME status ($GNOME_PROC)"
    else
        status "blocked: kernel GNOME status missing ($GNOME_PROC)"
        ok=1
    fi

    if have_command rustos-dbus-probe; then
        rustos-dbus-probe && status "ready: D-Bus session probe" || {
            status "blocked: D-Bus session probe failed"
            ok=1
        }
    fi

    if have_command rustos-wayland-probe; then
        rustos-wayland-probe && status "ready: Wayland/Mutter probe" || {
            status "blocked: Wayland/Mutter probe failed"
            ok=1
        }
    fi

    if have_command rustos-mutter; then
        rustos-mutter --probe && status "ready: Mutter/Wayland compositor" || {
            status "blocked: Mutter/Wayland compositor unavailable"
            ok=1
        }
    elif have_command mutter; then
        status "ready: userspace Mutter binary"
    else
        status "blocked: Mutter compositor missing"
        ok=1
    fi

    shell_ready=$(read_proc_key shell_ready)
    if [ "$shell_ready" = yes ]; then
        status "ready: kernel reports GNOME shell prerequisites"
    else
        status "info: kernel shell prerequisites incomplete ($shell_ready) — bridge mode"
    fi

    return "$ok"
}

print_env() {
    printf 'XDG_RUNTIME_DIR=%s\n' "$XDG_RUNTIME_DIR"
    printf 'DBUS_SESSION_BUS_ADDRESS=%s\n' "$DBUS_SESSION_BUS_ADDRESS"
    printf 'XDG_CURRENT_DESKTOP=%s\n' "$XDG_CURRENT_DESKTOP"
    printf 'XDG_SESSION_TYPE=%s\n' "$XDG_SESSION_TYPE"
    printf 'WAYLAND_DISPLAY=%s\n' "$WAYLAND_DISPLAY"
}

launch_compositor() {
    if have_command mutter; then
        status "launch: userspace mutter"
        exec mutter --wayland --wayland-display="$WAYLAND_DISPLAY" "$@"
    fi

    if have_command rustos-mutter; then
        status "launch: rustos-mutter compositor bridge"
        exec rustos-mutter --serve "$@"
    fi

    status "blocked: no compositor launcher available"
    return 1
}

launch_bridge_session() {
    status "launch: GNOME desktop bridge (kernel compositor + session supervisor)"

    if have_command rustos-mutter; then
        rustos-mutter --serve &
        status "ready: compositor bridge PID $!"
    fi

    while :; do
        sleep 300
        if [ -r "$GNOME_PROC" ]; then
            status "heartbeat: wayland=$(read_proc_key wayland) mutter=$(read_proc_key mutter) shell=$(read_proc_key shell_ready)"
        fi
    done
}

case "${1:-}" in
    --probe|--status)
        probe_foundation
        exit $?
        ;;
    --print-env)
        print_env
        exit 0
        ;;
    --compositor)
        shift
        probe_foundation || status "warning: compositor launch with degraded foundation"
        launch_compositor "$@"
        ;;
esac

probe_foundation || status "warning: continuing desktop boot with degraded foundation"

apply_ubuntu_theme

if have_command gnome-session; then
    if [ -f /usr/share/gnome-session/sessions/ubuntu.session ]; then
        status "launch: gnome-session (ubuntu)"
        exec gnome-session --session=ubuntu
    fi
    status "launch: gnome-session (gnome)"
    exec gnome-session --session=gnome
fi

if have_command gnome-session-binary; then
    status "launch: gnome-session-binary"
    exec gnome-session-binary --session=gnome
fi

if have_command gnome-shell; then
    if have_command rustos-mutter; then
        rustos-mutter --serve &
        status "launch: gnome-shell --wayland (compositor bridge PID $!)"
    fi
    status "launch: gnome-shell --wayland"
    exec gnome-shell --wayland
fi

launch_bridge_session
