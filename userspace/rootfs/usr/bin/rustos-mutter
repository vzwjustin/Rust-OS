#!/bin/sh
# RustOS Mutter launcher.

set -u

RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/0}
WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
SOCKET="$RUNTIME_DIR/$WAYLAND_DISPLAY"

export XDG_RUNTIME_DIR=$RUNTIME_DIR
export WAYLAND_DISPLAY=$WAYLAND_DISPLAY
export GDK_BACKEND=${GDK_BACKEND:-wayland}
export CLUTTER_BACKEND=${CLUTTER_BACKEND:-wayland}

log() {
    echo "rustos-mutter: $*"
}

real_mutter() {
    candidate=$(command -v mutter 2>/dev/null || true)
    if [ -n "$candidate" ] && [ "$candidate" != "/usr/bin/rustos-mutter" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    return 1
}

probe_socket() {
    if [ -S "$SOCKET" ] || [ -e "$SOCKET" ]; then
        log "ready: Wayland display socket ($SOCKET)"
        return 0
    fi

    log "blocked: Wayland display socket missing ($SOCKET)"
    return 1
}

serve_kernel_compositor() {
    probe_socket || exit 1
    log "serving kernel Wayland compositor on $SOCKET"
    while :; do
        if ! probe_socket >/dev/null 2>&1; then
            log "warning: Wayland socket lost"
            exit 1
        fi
        sleep 3600
    done
}

case "${1:-}" in
    --probe)
        if real_mutter >/dev/null; then
            log "ready: userspace Mutter ($(real_mutter))"
            exit 0
        fi
        probe_socket
        exit $?
        ;;
    --print-env)
        printf 'XDG_RUNTIME_DIR=%s\n' "$XDG_RUNTIME_DIR"
        printf 'WAYLAND_DISPLAY=%s\n' "$WAYLAND_DISPLAY"
        exit 0
        ;;
    --serve)
        if mutter_bin=$(real_mutter); then
            log "serve: delegating to userspace Mutter ($mutter_bin)"
            exec "$mutter_bin" --wayland --wayland-display="$WAYLAND_DISPLAY"
        fi
        serve_kernel_compositor
        ;;
esac

if mutter_bin=$(real_mutter); then
    exec "$mutter_bin" --wayland --wayland-display="$WAYLAND_DISPLAY" "$@"
fi

probe_socket || exit 1
log "using kernel Wayland compositor on $SOCKET until userspace Mutter is installed"
serve_kernel_compositor
