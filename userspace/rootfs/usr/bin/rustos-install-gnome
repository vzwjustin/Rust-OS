#!/bin/sh
# Install GNOME desktop packages on RustOS using Alpine apk (linux compat userspace).
#
# Run this inside a booted RustOS session (serial console or future terminal).
# Requires network access from the kernel network stack for apk fetch.

set -u

log() {
    echo "rustos-install-gnome: $*"
}

if ! command -v apk >/dev/null 2>&1; then
    log "blocked: /sbin/apk not found in rootfs"
    exit 1
fi

if [ "$(id -u)" != "0" ]; then
    log "blocked: must run as root"
    exit 1
fi

log "installing GNOME session stack via Alpine apk on RustOS..."

apk update || log "warning: apk update failed (network may be unavailable)"

apk add --no-cache \
    gnome-session \
    gnome-shell \
    gnome-settings-daemon \
    gsettings-desktop-schemas \
    adwaita-icon-theme \
    cantarell-fonts \
    || {
        log "blocked: apk install failed"
        exit 1
    }

if command -v mutter >/dev/null 2>&1; then
    log "ready: userspace mutter already present"
else
    log "info: mutter not in apk set; kernel compositor bridge remains active"
    log "info: build mutter with scripts/build-mutter.sh and copy to /usr/bin/mutter"
fi

if command -v gnome-session >/dev/null 2>&1 && command -v gnome-shell >/dev/null 2>&1; then
    log "ready: gnome-session and gnome-shell installed"
    log "restart session: exec /usr/bin/rustos-gnome-session"
else
    log "blocked: GNOME binaries missing after install"
    exit 1
fi

exit 0
