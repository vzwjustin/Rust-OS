#!/bin/sh
# RustOS installer UI — GTK/zenity when available, text wizard otherwise.
# chmod +x userspace/rootfs/usr/bin/rustos-installer-ui

set -u

CONF=${RUSTOS_INSTALLER_CONF:-/etc/rustos/installer.conf}
. "$CONF" 2>/dev/null || true

: "${plan_file:=/tmp/rustos-install.plan}"
: "${kernel_mode:=/proc/rustos/installer/mode}"
: "${kernel_proc:=/proc/rustos/installer}"
: "${default_hostname:=rustos}"
: "${default_username:=rustos}"
: "${default_fullname:=RustOS User}"
: "${default_timezone:=UTC}"
: "${default_locale:=en_US.UTF-8}"
: "${installer_backend:=/usr/bin/rustos-installer}"

INSTALLER_LOG=/run/rustos-installer-ui.log

log() {
    echo "rustos-installer-ui: $*"
    mkdir -p /run/installer 2>/dev/null || true
    printf '%s\n' "rustos-installer-ui: $*" >> "$INSTALLER_LOG" 2>/dev/null || true
}

have() {
    command -v "$1" >/dev/null 2>&1
}

read_input() {
    prompt=$1
    default=${2:-}
    if [ -n "$default" ]; then
        printf '%s [%s]: ' "$prompt" "$default" >&2
    else
        printf '%s: ' "$prompt" >&2
    fi
    IFS= read -r answer || answer=""
    if [ -z "$answer" ]; then
        answer=$default
    fi
    printf '%s' "$answer"
}

read_password() {
    prompt=$1
    printf '%s: ' "$prompt" >&2
    if have stty; then
        stty -echo 2>/dev/null || true
        IFS= read -r pass || pass=""
        stty echo 2>/dev/null || true
        echo >&2
    else
        IFS= read -r pass || pass=""
    fi
    printf '%s' "$pass"
}

confirm() {
    prompt=$1
    answer=$(read_input "$prompt (yes/no)" "no")
    case "$answer" in
        y|Y|yes|YES) return 0 ;;
        *) return 1 ;;
    esac
}


bootstrap_graphical_session() {
    export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/0}"
    export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
    export GDK_BACKEND=wayland
    export GTK_THEME="${GTK_THEME:-Adwaita:dark}"
    export NO_AT_BRIDGE=1
    mkdir -p "$XDG_RUNTIME_DIR" 2>/dev/null || true
    chmod 700 "$XDG_RUNTIME_DIR" 2>/dev/null || true

    sock="$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY"
    if [ ! -S "$sock" ]; then
        if have rustos-mutter; then
            log "starting compositor for GTK"
            rustos-mutter --serve &
            sleep 2
        elif have mutter; then
            mutter --wayland --wayland-display="$WAYLAND_DISPLAY" &
            sleep 2
        fi
    fi

    export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$XDG_RUNTIME_DIR/bus}"
    if [ ! -S "$XDG_RUNTIME_DIR/bus" ] && have dbus-daemon; then
        dbus-daemon --session --fork --nopidfile --address="$DBUS_SESSION_BUS_ADDRESS" 2>/dev/null || true
    fi

    if have zenity && zenity --version >/dev/null 2>&1; then
        return 0
    fi
    return 1
}

graphical_available() {
    if [ "${RUSTOS_FORCE_GTK:-0}" = 1 ]; then
        bootstrap_graphical_session && return 0
    fi
    if bootstrap_graphical_session; then
        return 0
    fi
    if [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
        if have zenity || have yad; then
            return 0
        fi
    fi
    return 1
}

delegate_kernel_wizard() {
    if [ -w "$kernel_mode" ]; then
        log "delegating to kernel installer wizard"
        echo install >"$kernel_mode"
        if [ -r "$kernel_proc" ]; then
            log "kernel wizard active — monitor $kernel_proc"
            while :; do
                state=$(grep -E '^state=' "$kernel_proc" 2>/dev/null | head -n1 | cut -d= -f2-)
                case "$state" in
                    complete|done|success)
                        log "kernel wizard finished"
                        return 0
                        ;;
                    failed|error|cancelled)
                        log "kernel wizard failed"
                        return 1
                        ;;
                esac
                sleep 2
            done
        fi
        return 0
    fi
    return 1
}

zenity_pick_disk() {
    tmp=/tmp/rustos-disks.$$
    if ! $installer_backend list-disks 2>/dev/null >"$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    args=""
    while IFS="$(printf '\t')" read -r disk size; do
        [ -n "$disk" ] || continue
        args="$args $disk $size"
    done <"$tmp"
    rm -f "$tmp"
    [ -n "$args" ] || return 1
    # shellcheck disable=SC2086
    zenity --list --title="RustOS Installer" --text="Select installation disk" \
        --column="Disk" --column="Size" $args 2>/dev/null
}

zenity_wizard() {
    have zenity || return 1

    zenity --info --title="Install RustOS" --text="Welcome to the RustOS installer.

This is the graphical installer (GTK).\n\nThis will guide you through disk setup, user creation, and system installation." --width=420 2>/dev/null || true

    lang=$(zenity --list --title="Install RustOS" --text="Choose your language" --column="Language" "English" "Español" "Français" "Deutsch" 2>/dev/null) || lang=English
    log "language: $lang"

    disk=$(zenity_pick_disk) || {
        zenity --error --text="No install disks detected." 2>/dev/null || true
        return 1
    }

    form=$(zenity --forms --title="RustOS Installer" --text="Configure your installation" \
        --add-entry="Computer name" --add-entry="Username" --add-entry="Full name" \
        --add-entry="Timezone" --add-entry="Locale" \
        --form-text="Defaults are suitable for most installs." 2>/dev/null) || return 1

    hostname=$(printf '%s' "$form" | sed -n '1p')
    username=$(printf '%s' "$form" | sed -n '2p')
    fullname=$(printf '%s' "$form" | sed -n '3p')
    timezone=$(printf '%s' "$form" | sed -n '4p')
    locale=$(printf '%s' "$form" | sed -n '5p')

  pass1=$(zenity --password --title="RustOS Installer" --text="Choose a password for $username" 2>/dev/null) || return 1
    pass2=$(zenity --password --title="RustOS Installer" --text="Confirm password" 2>/dev/null) || return 1
    if [ "$pass1" != "$pass2" ]; then
        zenity --error --text="Passwords do not match." 2>/dev/null || true
        return 1
    fi

    zenity --question --title="RustOS Installer" --text="Install RustOS to $disk?\n\nALL DATA ON THIS DISK WILL BE ERASED." --default-cancel 2>/dev/null || return 1

    write_custom_plan "$disk" "$hostname" "$username" "$fullname" "$pass1" "$timezone" "$locale" || return 1

    (
        echo "10"; echo "# Partitioning and formatting..."
        sleep 1
        echo "40"; echo "# Copying system files..."
        $installer_backend apply "$plan_file"
        rc=$?
        echo "100"; echo "# Done."
        exit $rc
    ) | zenity --progress --title="RustOS Installer" --text="Installing RustOS..." --percentage=0 --auto-close 2>/dev/null
    return $?
}

write_custom_plan() {
    disk=$1
    hostname=${2:-$default_hostname}
    username=${3:-$default_username}
    fullname=${4:-$default_fullname}
    password=${5:-}
    timezone=${6:-$default_timezone}
    locale=${7:-$default_locale}

    $installer_backend plan-default >/dev/null 2>&1 || true
    if [ ! -f "$plan_file" ]; then
        mkdir -p "$(dirname "$plan_file")" 2>/dev/null || true
        : >"$plan_file"
    fi

    if have sed; then
        for key in disk hostname username fullname password timezone locale; do
            eval val=\$$key
            if grep -q "^${key}=" "$plan_file" 2>/dev/null; then
                sed -i "s|^${key}=.*|${key}=${val}|" "$plan_file"
            else
                echo "${key}=${val}" >>"$plan_file"
            fi
        done
    else
        cat >>"$plan_file" <<EOF
disk=$disk
hostname=$hostname
username=$username
fullname=$fullname
password=$password
timezone=$timezone
locale=$locale
EOF
    fi

    case "$disk" in
        /dev/nvme*|/dev/mmcblk*)
            efi_part="${disk}p1"
            root_part="${disk}p2"
            swap_part="${disk}p3"
            ;;
        *)
            efi_part="${disk}1"
            root_part="${disk}2"
            swap_part="${disk}3"
            ;;
    esac
    for pair in "efi_part=$efi_part" "root_part=$root_part" "swap_part=$swap_part"; do
        key=${pair%%=*}
        val=${pair#*=}
        if grep -q "^${key}=" "$plan_file" 2>/dev/null; then
            sed -i "s|^${key}=.*|${key}=${val}|" "$plan_file" 2>/dev/null || true
        else
            echo "$pair" >>"$plan_file"
        fi
    done
    return 0
}

text_wizard() {
    echo ""
    echo "=============================================="
    echo "       Welcome to the RustOS Installer"
    echo "=============================================="
    echo ""
    echo "This wizard will help you install RustOS on"
    echo "your computer. You can try the live desktop"
    echo "first, then return here to install."
    echo ""

    if ! confirm "Continue with installation?"; then
        log "user cancelled at welcome"
        return 1
    fi

    echo ""
    echo "--- Keyboard layout ---"
    echo "Using system default layout."
    read_input "Press Enter to continue" "" >/dev/null

    echo ""
    echo "--- Network ---"
    echo "RustOS will configure networking after install."
    read_input "Press Enter to continue" "" >/dev/null

    echo ""
    echo "--- Updates and other software ---"
    echo "Standard RustOS desktop will be installed."
    read_input "Press Enter to continue" "" >/dev/null

    echo ""
    echo "--- Installation type ---"
    echo "Erase disk and install RustOS (recommended for QEMU/dev images)."
    if ! confirm "Use guided erase-disk install?"; then
        log "user declined erase-disk install"
        return 1
    fi

    echo ""
    echo "--- Disks ---"
    if ! $installer_backend list-disks; then
        echo "No disks found. Cannot continue."
        return 1
    fi
    disk=$(read_input "Install disk (e.g. /dev/sda)" "")
    if [ -z "$disk" ] || [ ! -b "$disk" ]; then
        echo "Invalid disk: $disk"
        return 1
    fi

    echo ""
    echo "--- Where are you? ---"
    timezone=$(read_input "Timezone" "$default_timezone")

    echo ""
    echo "--- Who are you? ---"
    fullname=$(read_input "Your name" "$default_fullname")
    username=$(read_input "Username" "$default_username")
    hostname=$(read_input "Computer name" "$default_hostname")
    locale=$(read_input "Locale" "$default_locale")

    echo ""
    pass1=$(read_password "Choose a password")
    pass2=$(read_password "Confirm password")
    if [ "$pass1" != "$pass2" ]; then
        echo "Passwords do not match."
        return 1
    fi

    echo ""
    echo "=============================================="
    echo " Summary"
    echo "=============================================="
    echo " Disk:      $disk (entire disk will be erased)"
    echo " Name:      $fullname"
    echo " Username:  $username"
    echo " Hostname:  $hostname"
    echo " Timezone:  $timezone"
    echo " Locale:    $locale"
    echo "=============================================="
    echo ""

    if ! confirm "Write changes and begin installation?"; then
        log "user cancelled at confirmation"
        return 1
    fi

    write_custom_plan "$disk" "$hostname" "$username" "$fullname" "$pass1" "$timezone" "$locale" || return 1

    echo ""
    echo "Installing RustOS — this may take several minutes..."
    mkdir -p /run/installer 2>/dev/null || true
    echo active >/run/installer/active 2>/dev/null || true

    if $installer_backend apply "$plan_file"; then
        echo ""
        echo "Installation complete. Remove install media and reboot."
        return 0
    fi

    echo ""
    echo "Installation failed. See $INSTALLER_LOG and /run/rustos-installer.log"
    return 1
}

main() {
    mkdir -p /run/installer 2>/dev/null || true
    echo active >/run/installer/active 2>/dev/null || true

    log "starting installer UI"

    if [ ! -x "$installer_backend" ]; then
        installer_backend=rustos-installer
    fi

    if graphical_available; then
        if zenity_wizard; then
            log "graphical install complete"
            return 0
        fi
        log "graphical wizard unavailable or cancelled — falling back"
    fi

    if delegate_kernel_wizard; then
        return $?
    fi

    text_wizard
}

main "$@"
