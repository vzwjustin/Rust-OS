#!/bin/sh
# Probe the in-kernel D-Bus session bus via /proc/rustos/gnome.

set -u

PROC=${RUSTOS_GNOME_PROC:-/proc/rustos/gnome}

log() {
    echo "rustos-dbus-probe: $*"
}

if [ ! -r "$PROC" ]; then
    log "blocked: $PROC missing"
    exit 1
fi

ok=0

read_proc() {
    grep -E "^$1=" "$PROC" 2>/dev/null | head -n1 | cut -d= -f2-
}

dbus_state=$(read_proc dbus)
if [ "$dbus_state" = ready ]; then
    log "ready: D-Bus message bus"
else
    log "blocked: D-Bus message bus ($dbus_state)"
    ok=1
fi

for name in \
    org_freedesktop_DBus \
    org_gnome_Shell \
    org_rustos_GnomeReadiness
do
    value=$(grep -E "^name_has_owner_${name}=" "$PROC" 2>/dev/null | head -n1 | cut -d= -f2-)
    case "$value" in
        yes)
            log "ready: NameHasOwner ${name#org_}"
            ;;
        *)
            log "blocked: NameHasOwner ${name#org_} ($value)"
            ok=1
            ;;
    esac
done

foundation=$(read_proc foundation_ready)
if [ "$foundation" = yes ]; then
    log "ready: GNOME foundation"
else
    log "blocked: GNOME foundation ($foundation)"
    ok=1
fi

exit "$ok"
