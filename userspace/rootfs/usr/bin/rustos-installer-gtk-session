#!/bin/sh
# Bootstrap Wayland + D-Bus + GTK and launch the graphical RustOS installer.
set -u
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PATH
LIVE_SQUASH=${RUSTOS_LIVE_SQUASH:-/live/filesystem.squashfs}
LIVE_TAR=${RUSTOS_LIVE_TAR:-/live/filesystem.tar.gz}
UI=${RUSTOS_INSTALLER_UI:-/usr/bin/rustos-installer-ui}
log() { echo "rustos-installer-gtk-session: $*"; }
have() { command -v "$1" >/dev/null 2>&1; }
ensure_live_root() {
    if have zenity && ls /usr/lib/libgtk-4.so* >/dev/null 2>&1; then return 0; fi
    log "GTK/zenity missing — trying live filesystem"
    if [ -f "$LIVE_SQUASH" ] && have mount; then
        mkdir -p /run/live/root /run/live/upper /run/live/work /mnt/live 2>/dev/null || true
        if mount -t squashfs "$LIVE_SQUASH" /run/live/root 2>/dev/null; then
            if mount -t overlay overlay -o lowerdir=/run/live/root,upperdir=/run/live/upper,workdir=/run/live/work /mnt/live 2>/dev/null; then
                if [ -x /mnt/live/usr/bin/zenity ]; then
                    export PATH="/mnt/live/usr/bin:/mnt/live/bin:/mnt/live/sbin:$PATH"
                    export LD_LIBRARY_PATH="/mnt/live/usr/lib:/mnt/live/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
                    export GTK_THEME=Adwaita:dark
                    [ -x /mnt/live/usr/bin/rustos-installer-ui ] && UI=/mnt/live/usr/bin/rustos-installer-ui
                    return 0
                fi
            fi
        fi
    fi
    if [ -f "$LIVE_TAR" ] && have tar; then
        mkdir -p /run/live/extracted 2>/dev/null || true
        if [ ! -f /run/live/extracted/.extracted ]; then
            tar xzf "$LIVE_TAR" -C /run/live/extracted 2>/dev/null || true
            touch /run/live/extracted/.extracted 2>/dev/null || true
        fi
        if [ -x /run/live/extracted/usr/bin/zenity ]; then
            export PATH="/run/live/extracted/usr/bin:/run/live/extracted/bin:$PATH"
            export LD_LIBRARY_PATH="/run/live/extracted/usr/lib:/run/live/extracted/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
            UI=/run/live/extracted/usr/bin/rustos-installer-ui
            return 0
        fi
    fi
    return 1
}
bootstrap_wayland() {
    export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/0}"
    export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
    export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-ubuntu:GNOME}"
    export XDG_SESSION_DESKTOP=ubuntu
    export XDG_SESSION_TYPE=wayland
    export GDK_BACKEND=wayland
    export GTK_THEME="${GTK_THEME:-Adwaita:dark}"
    export NO_AT_BRIDGE=1
    mkdir -p "$XDG_RUNTIME_DIR" && chmod 700 "$XDG_RUNTIME_DIR" 2>/dev/null || true
    sock="$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY"
    [ -S "$sock" ] && return 0
    if have rustos-mutter; then rustos-mutter --serve & sleep 2
    elif have mutter; then mutter --wayland --wayland-display="$WAYLAND_DISPLAY" & sleep 2; fi
    [ -S "$sock" ]
}
bootstrap_dbus() {
    export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$XDG_RUNTIME_DIR/bus}"
    [ -S "$XDG_RUNTIME_DIR/bus" ] && return 0
    have dbus-daemon && dbus-daemon --session --fork --nopidfile --address="$DBUS_SESSION_BUS_ADDRESS" 2>/dev/null || true
}
main() {
    mkdir -p /run/installer; echo active >/run/installer/active 2>/dev/null || true
    export RUSTOS_BOOT=install
    ensure_live_root || log "no live overlay"
    bootstrap_wayland || true
    bootstrap_dbus || true
    if ! have zenity || ! zenity --version >/dev/null 2>&1; then
        log "zenity unavailable — text installer"
        exec /usr/bin/rustos-installer-ui "$@"
    fi
    log "GTK installer (zenity + Wayland)"
    export RUSTOS_FORCE_GTK=1
    exec "$UI" "$@"
}
main "$@"
