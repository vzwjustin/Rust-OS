#!/bin/sh
# RustOS CLI installer backend — kernel proc bridge + userspace fallback.
# chmod +x userspace/rootfs/usr/bin/rustos-installer

set -u

CONF=${RUSTOS_INSTALLER_CONF:-/etc/rustos/installer.conf}
. "$CONF" 2>/dev/null || true

: "${plan_file:=/tmp/rustos-install.plan}"
: "${status_file:=/run/rustos-installer.status}"
: "${log_file:=/run/rustos-installer.log}"
: "${kernel_proc:=/proc/rustos/installer}"
: "${kernel_plan:=/proc/rustos/installer/plan}"
: "${kernel_mode:=/proc/rustos/installer/mode}"
: "${kernel_apply:=/proc/rustos/installer/apply}"
: "${default_hostname:=rustos}"
: "${default_username:=rustos}"
: "${default_fullname:=RustOS User}"
: "${default_timezone:=UTC}"
: "${default_locale:=en_US.UTF-8}"
: "${default_disk_glob:=/dev/sd?}"
: "${efi_size_mb:=512}"
: "${swap_size_mb:=2048}"
: "${root_fs:=ext4}"
: "${efi_fs:=vfat}"
: "${source_root:=/}"
: "${target_mount:=/mnt/rustos-target}"
: "${efi_mount:=/mnt/rustos-target/boot/efi}"
: "${installed_marker:=/etc/rustos-installed}"
: "${postinstall_script:=/usr/bin/rustos-installer-postinstall}"

log() {
    msg="rustos-installer: $*"
    echo "$msg"
    mkdir -p "$(dirname "$log_file")" 2>/dev/null || true
    printf '%s\n' "$msg" >> "$log_file" 2>/dev/null || true
}

status_line() {
    mkdir -p "$(dirname "$status_file")" 2>/dev/null || true
    printf '%s\n' "$*" >> "$status_file" 2>/dev/null || true
}

have() {
    command -v "$1" >/dev/null 2>&1
}

read_proc_key() {
    key=$1
    default=${2:-}

    case "$key" in
        state|status)
            if [ -r "$kernel_proc/status" ]; then
                head -n1 "$kernel_proc/status" 2>/dev/null || printf '%s\n' "$default"
                return 0
            fi
            ;;
        progress)
            if [ -r "$kernel_proc/progress" ]; then
                head -n1 "$kernel_proc/progress" 2>/dev/null || printf '%s\n' "$default"
                return 0
            fi
            ;;
    esac

    if [ ! -r "$kernel_proc" ]; then
        printf '%s\n' "$default"
        return 0
    fi
    value=$(grep -E "^${key}=" "$kernel_proc" 2>/dev/null | head -n1 | cut -d= -f2-)
    if [ -n "$value" ]; then
        printf '%s\n' "$value"
    else
        printf '%s\n' "$default"
    fi
}

disk_size_bytes() {
    disk=$1
    if [ -r "/sys/class/block/$(basename "$disk")/size" ]; then
        sectors=$(cat "/sys/class/block/$(basename "$disk")/size" 2>/dev/null)
        echo $((sectors * 512))
        return 0
    fi
    if have blockdev; then
        blockdev --getsize64 "$disk" 2>/dev/null && return 0
    fi
    echo 0
}

human_size() {
    bytes=$1
    if [ "$bytes" -ge 1073741824 ]; then
        echo "$((bytes / 1073741824))G"
    elif [ "$bytes" -ge 1048576 ]; then
        echo "$((bytes / 1048576))M"
    else
        echo "${bytes}B"
    fi
}

list_block_disks() {
    for pattern in /dev/sd? /dev/vd? /dev/nvme?n? /dev/hd?; do
        for disk in $pattern; do
            [ -b "$disk" ] || continue
            case "$disk" in
                *[0-9]) continue ;;
            esac
            if [ -r "/sys/class/block/$(basename "$disk")/size" ] || have blockdev; then
                echo "$disk"
            fi
        done
    done
}

pick_default_disk() {
    if [ -n "${RUSTOS_INSTALL_DISK:-}" ] && [ -b "$RUSTOS_INSTALL_DISK" ]; then
        echo "$RUSTOS_INSTALL_DISK"
        return 0
    fi

    kernel_disk=$(read_proc_key default_disk "")
    if [ -n "$kernel_disk" ] && [ -b "$kernel_disk" ]; then
        echo "$kernel_disk"
        return 0
    fi

    largest=""
    largest_bytes=0
    for disk in $(list_block_disks); do
        bytes=$(disk_size_bytes "$disk")
        if [ "$bytes" -gt "$largest_bytes" ]; then
            largest_bytes=$bytes
            largest=$disk
        fi
    done

    if [ -n "$largest" ]; then
        echo "$largest"
        return 0
    fi

    for disk in $default_disk_glob; do
        [ -b "$disk" ] && echo "$disk" && return 0
    done

    return 1
}

partition_paths() {
    disk=$1
    case "$disk" in
        /dev/nvme*|/dev/mmcblk*)
            echo "${disk}p1 ${disk}p2 ${disk}p3"
            ;;
        *)
            echo "${disk}1 ${disk}2 ${disk}3"
            ;;
    esac
}

kernel_device_id() {
    disk=$1
    base=${disk##*/}
    case "$base" in
        sd?)
            letter=${base#sd}
            idx=0
            for c in a b c d e f g h i j k l m n o p q r s t u v w x y z; do
                if [ "$letter" = "$c" ]; then
                    echo "$idx"
                    return 0
                fi
                idx=$((idx + 1))
            done
            ;;
        nvme*n*|mmcblk*)
            echo 0
            return 0
            ;;
    esac
    echo 0
}

password_hash_for_plan() {
    password=$1
    if [ -z "$password" ]; then
        echo "*"
        return 0
    fi

    if have openssl; then
        hash=$(printf '%s' "$password" | openssl passwd -6 -stdin 2>/dev/null || true)
        if [ -n "$hash" ]; then
            printf '%s\n' "$hash"
            return 0
        fi
    fi

    echo "*"
}

write_plan() {
    outfile=$1
    disk=$2
    hostname=${3:-$default_hostname}
    username=${4:-$default_username}
    fullname=${5:-$default_fullname}
    password=${6:-}
    timezone=${7:-$default_timezone}
    locale=${8:-$default_locale}

    set -- $(partition_paths "$disk")
    efi_part=$1
    root_part=$2
    swap_part=$3
    target_device_id=$(kernel_device_id "$disk")
    include_swap=false
    if [ "${swap_size_mb:-0}" -gt 0 ] 2>/dev/null; then
        include_swap=true
    fi
    password_hash=$(password_hash_for_plan "$password")

    mkdir -p "$(dirname "$outfile")" 2>/dev/null || true
    cat >"$outfile" <<EOF
# RustOS install plan — generated $(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo unknown)
version=1
disk=$disk
target_device_id=$target_device_id
erase_disk=true
include_swap=$include_swap
efi_part=$efi_part
root_part=$root_part
swap_part=$swap_part
efi_fs=$efi_fs
root_fs=$root_fs
efi_size_mb=$efi_size_mb
swap_size_mb=$swap_size_mb
hostname=$hostname
username=$username
fullname=$fullname
full_name=$fullname
password=$password
password_hash=$password_hash
timezone=$timezone
locale=$locale
language=$locale
source_root=$source_root
target_mount=$target_mount
efi_mount=$efi_mount
installed_marker=$installed_marker
postinstall_script=$postinstall_script
EOF
}

read_plan_value() {
    file=$1
    key=$2
    grep -E "^${key}=" "$file" 2>/dev/null | head -n1 | cut -d= -f2-
}

cmd_probe() {
    ok=0
    : > "$status_file" 2>/dev/null || true

    log "probe: RustOS installer backend"
    status_line "probe: start"

    if [ -r "$kernel_proc" ]; then
        log "ready: kernel installer proc ($kernel_proc)"
        status_line "kernel_proc: ready"
        cat "$kernel_proc" 2>/dev/null | while IFS= read -r line; do
            status_line "kernel: $line"
        done
    else
        log "info: kernel installer proc missing ($kernel_proc) — userspace fallback"
        status_line "kernel_proc: missing"
    fi

    for tool in sh cp mkdir mount umount tar sync mkfs.ext4 mkfs.vfat fdisk losetup; do
        if have "$tool"; then
            status_line "tool: $tool ready"
        else
            status_line "tool: $tool missing"
            case "$tool" in
                sh|cp|mkdir) ok=1 ;;
            esac
        fi
    done

    disks=$(list_block_disks)
    if [ -n "$disks" ]; then
        log "ready: block devices detected"
        for disk in $disks; do
            size=$(human_size "$(disk_size_bytes "$disk")")
            log "  disk $disk ($size)"
            status_line "disk: $disk size=$size"
        done
    else
        log "blocked: no block devices found"
        status_line "disks: none"
        ok=1
    fi

    if pick_default_disk >/dev/null 2>&1; then
        log "ready: default disk $(pick_default_disk)"
    else
        log "blocked: no default disk"
        ok=1
    fi

    status_line "probe: exit=$ok"
    return "$ok"
}

cmd_list_disks() {
    found=0
    for disk in $(list_block_disks); do
        found=1
        bytes=$(disk_size_bytes "$disk")
        printf '%s\t%s\n' "$disk" "$(human_size "$bytes")"
    done
    if [ "$found" -eq 0 ]; then
        log "list-disks: no candidates"
        return 1
    fi
    return 0
}

cmd_plan_default() {
    disk=$(pick_default_disk) || {
        log "plan-default: no install disk"
        return 1
    }

    write_plan "$plan_file" "$disk" "$default_hostname" "$default_username" "$default_fullname" "" "$default_timezone" "$default_locale"
    log "plan-default: wrote $plan_file for disk $disk"
    cat "$plan_file"
    return 0
}

kernel_apply_plan() {
    plan=$1
    if [ -w "$kernel_plan" ]; then
        log "apply: submitting plan to $kernel_plan"
        cat "$plan" >"$kernel_plan" || return 1
    fi
    if [ -w "$kernel_apply" ]; then
        log "apply: triggering kernel install via $kernel_apply"
        echo apply >"$kernel_apply" || return 1
        return 0
    fi
    if [ -w "$kernel_mode" ]; then
        log "apply: requesting kernel install mode via $kernel_mode"
        echo install >"$kernel_mode" 2>/dev/null || true
    fi
    return 1
}

wait_kernel_install() {
    i=0
    while [ "$i" -lt 120 ]; do
        state=$(read_proc_key state "unknown")
        case "$state" in
            complete|done|success)
                log "apply: kernel reports install complete"
                return 0
                ;;
            failed|error)
                log "apply: kernel reports install failed"
                return 1
                ;;
        esac
        if [ -r "$kernel_proc" ]; then
            progress=$(read_proc_key progress "")
            [ -n "$progress" ] && log "apply: kernel progress $progress"
        fi
        sleep 1
        i=$((i + 1))
    done
    log "apply: kernel install timed out"
    return 1
}

format_partition() {
    part=$1
    fstype=$2
    label=$3

    [ -b "$part" ] || return 1
    log "format: $part as $fstype"
    case "$fstype" in
        ext4)
            if have mkfs.ext4; then
                mkfs.ext4 -F -L "$label" "$part"
            else
                log "format: mkfs.ext4 unavailable"
                return 1
            fi
            ;;
        vfat|fat32)
            if have mkfs.vfat; then
                mkfs.vfat -F 32 -n "$label" "$part"
            elif have mkfs.fat; then
                mkfs.fat -F 32 -n "$label" "$part"
            else
                log "format: mkfs.vfat unavailable"
                return 1
            fi
            ;;
        swap)
            if have mkswap; then
                mkswap -L "$label" "$part"
            else
                log "format: mkswap unavailable"
                return 1
            fi
            ;;
        *)
            log "format: unsupported fstype $fstype"
            return 1
            ;;
    esac
}

partition_disk_userspace() {
    disk=$1
    efi_mb=$2
    swap_mb=$3

    if ! have fdisk && ! have sfdisk; then
        log "partition: no fdisk/sfdisk — assuming existing partitions"
        return 0
    fi

    log "partition: laying out $disk (EFI ${efi_mb}M, swap ${swap_mb}M, root rest)"
    if have sfdisk; then
        printf 'label: gpt\n,+%dM,U\n,+%dM,S\n,,L\n' "$efi_mb" "$swap_mb" | sfdisk "$disk"
    elif have fdisk; then
        (
            echo g
            echo n
            echo
            echo
            echo "+${efi_mb}M"
            echo t
            echo 1
            echo 1
            echo n
            echo
            echo
            echo "+${swap_mb}M"
            echo t
            echo 2
            echo 19
            echo n
            echo
            echo
            echo
            echo t
            echo 3
            echo 20
            echo w
        ) | fdisk "$disk"
    fi
    sleep 1
    if have partprobe; then
        partprobe "$disk" 2>/dev/null || true
    fi
}

copy_rootfs_userspace() {
    src=$1
    dest=$2
    log "copy: $src -> $dest"

    mkdir -p "$dest" || return 1

    excludes="
--exclude=/proc
--exclude=/sys
--exclude=/dev
--exclude=/run
--exclude=/tmp
--exclude=$target_mount
--exclude=/mnt
--exclude=/live
"

    if have tar && have cp; then
        (
            cd "$src" || exit 1
            tar $excludes -cf - . 2>/dev/null
        ) | (
            cd "$dest" || exit 1
            tar -xf - 2>/dev/null
        ) && return 0
    fi

    if have cp; then
        for item in bin sbin usr etc lib var opt home root boot; do
            if [ -e "${src}/${item}" ]; then
                mkdir -p "$dest/$item"
                cp -a "${src}/${item}/." "$dest/$item/" 2>/dev/null || cp -r "${src}/${item}" "$dest/" 2>/dev/null || true
            fi
        done
        return 0
    fi

    log "copy: no tar/cp available"
    return 1
}

write_installed_target_metadata() {
    target=$1
    plan=$2

    disk=$(read_plan_value "$plan" disk)
    efi_part=$(read_plan_value "$plan" efi_part)
    root_part=$(read_plan_value "$plan" root_part)
    swap_part=$(read_plan_value "$plan" swap_part)
    hostname=$(read_plan_value "$plan" hostname)
    username=$(read_plan_value "$plan" username)

    mkdir -p "$target/etc" "$target/etc/rustos" 2>/dev/null || true
    cat >"$target$installed_marker" <<EOF
# RustOS installed system metadata
version=1
disk=$disk
efi_part=$efi_part
root_part=$root_part
swap_part=$swap_part
hostname=$hostname
username=$username
installed_at=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo unknown)
EOF

    cat >"$target/etc/fstab" <<EOF
# RustOS generated fstab
$root_part    /          $root_fs    defaults        0 1
$efi_part     /boot/efi  $efi_fs     defaults        0 2
$swap_part    none       swap        sw              0 0
EOF

    mkdir -p "$target/etc/rustos" 2>/dev/null || true
    cp "$plan" "$target/etc/rustos/install.plan" 2>/dev/null || true
    echo pending >"$target/etc/rustos/first-boot" 2>/dev/null || true
}

userspace_apply_plan() {
    plan=$1

    disk=$(read_plan_value "$plan" disk)
    efi_part=$(read_plan_value "$plan" efi_part)
    root_part=$(read_plan_value "$plan" root_part)
    swap_part=$(read_plan_value "$plan" swap_part)
    efi_fstype=$(read_plan_value "$plan" efi_fs)
    root_fstype=$(read_plan_value "$plan" root_fs)
    src=$(read_plan_value "$plan" source_root)
    target=$(read_plan_value "$plan" target_mount)
    efi_target=$(read_plan_value "$plan" efi_mount)
    efi_mb=$(read_plan_value "$plan" efi_size_mb)
    swap_mb=$(read_plan_value "$plan" swap_size_mb)

    [ -n "$disk" ] && [ -b "$disk" ] || {
        log "apply: invalid disk $disk"
        return 1
    }

    if [ ! -b "$efi_part" ] || [ ! -b "$root_part" ]; then
        partition_disk_userspace "$disk" "${efi_mb:-512}" "${swap_mb:-2048}"
        set -- $(partition_paths "$disk")
        efi_part=$1
        root_part=$2
        swap_part=$3
    fi

    format_partition "$efi_part" "$efi_fstype" RUSTOSEFI || return 1
    format_partition "$root_part" "$root_fstype" RUSTOSROOT || return 1
    if [ -b "$swap_part" ]; then
        format_partition "$swap_part" swap RUSTOSSWAP || true
    fi

    mkdir -p "$target" "$efi_target" || return 1
    mount -t "$root_fstype" "$root_part" "$target" || return 1
    mkdir -p "$efi_target"
    mount -t "$efi_fstype" "$efi_part" "$efi_target" || {
        umount "$target" 2>/dev/null || true
        return 1
    }

    copy_rootfs_userspace "$src" "$target" || {
        umount "$efi_target" 2>/dev/null || true
        umount "$target" 2>/dev/null || true
        return 1
    }

    write_installed_target_metadata "$target" "$plan"

    mkdir -p "$target/proc" "$target/sys" "$target/dev" "$target/run" 2>/dev/null || true
    if [ -x "$postinstall_script" ]; then
        log "apply: running postinstall in target"
        if have chroot; then
            mount -t proc proc "$target/proc" 2>/dev/null || true
            mount -t sysfs sysfs "$target/sys" 2>/dev/null || true
            mount --bind /dev "$target/dev" 2>/dev/null || true
            chroot "$target" "$postinstall_script" --chroot "$(basename "$plan")" || log "apply: postinstall returned non-zero"
            umount "$target/dev" 2>/dev/null || true
            umount "$target/sys" 2>/dev/null || true
            umount "$target/proc" 2>/dev/null || true
        fi
    fi

    sync
    umount "$efi_target" 2>/dev/null || true
    umount "$target" 2>/dev/null || true

    mkdir -p /etc 2>/dev/null || true
    cp "$target$installed_marker" "$installed_marker" 2>/dev/null || true
    mkdir -p /run/installer 2>/dev/null || true
    echo complete > /run/installer/status 2>/dev/null || true

    log "apply: userspace install complete on $root_part"
    return 0
}

cmd_apply() {
    plan=${1:-$plan_file}
    if [ ! -f "$plan" ]; then
        log "apply: plan missing ($plan)"
        return 1
    fi

    log "apply: using plan $plan"
    status_line "apply: start"

    if kernel_apply_plan "$plan"; then
        if wait_kernel_install; then
            status_line "apply: kernel complete"
            return 0
        fi
        log "apply: kernel path failed — trying userspace fallback"
    fi

    if list_block_disks | grep -q .; then
        userspace_apply_plan "$plan" && {
            status_line "apply: userspace complete"
            return 0
        }
    fi

    log "apply: all install paths failed"
    status_line "apply: failed"
    return 1
}

cmd_status() {
    if [ -f "$status_file" ]; then
        cat "$status_file"
    fi

    if [ -r "$kernel_proc" ]; then
        echo "--- kernel ---"
        cat "$kernel_proc"
    fi

    if [ -f /run/installer/status ]; then
        echo "--- runtime ---"
        cat /run/installer/status
    fi

    if [ -f "$installed_marker" ]; then
        echo "--- installed ---"
        cat "$installed_marker"
    fi

    if [ -f "$plan_file" ]; then
        echo "--- plan ---"
        cat "$plan_file"
    fi
    return 0
}

usage() {
    echo "Usage: rustos-installer <probe|list-disks|plan-default|apply [plan]|status>"
    return 1
}

case "${1:-}" in
    probe)
        cmd_probe
        ;;
    list-disks|list)
        cmd_list_disks
        ;;
    plan-default|plan)
        cmd_plan_default
        ;;
    apply)
        shift
        cmd_apply "${1:-}"
        ;;
    status)
        cmd_status
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
